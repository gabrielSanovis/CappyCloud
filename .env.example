# ──────────────────────────────────────────────────────────────
# CappyCloud — Environment Variables
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────

# ── OpenRouter (required) ─────────────────────────────────────
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Model to use via OpenRouter (OpenAI-compatible identifier)
# Preferir Claude/GPT-4 para tool use; modelos "free" costumam errar parâmetros (ex.: Grep).
# Examples:
#   openai/gpt-oss-120b:free
#   openai/gpt-4o
#   google/gemini-2.0-flash
OPENROUTER_MODEL=openai/gpt-oss-120b:free

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_USER=cappy
POSTGRES_PASSWORD=9UXlCZS9q85U
POSTGRES_DB=cappycloud

# ── LibreChat (UI) ────────────────────────────────────────────
LIBRECHAT_PORT=38080
HOST=0.0.0.0
PORT=3080
DOMAIN_CLIENT=http://localhost:38080
DOMAIN_SERVER=http://localhost:38080
APP_TITLE=CappyCloud
# Obrigatório: sem isto isEnabled(undefined)=false e ninguém consegue registar-se
ALLOW_REGISTRATION=true
ENDPOINTS=custom
OPENAI_API_KEY=not-used
ANTHROPIC_API_KEY=not-used
GOOGLE_KEY=not-used
JWT_SECRET=6c1f60e77ffca474b3240a781a785f9dfedc899bc574cbbd031e75487a6340bf
JWT_REFRESH_SECRET=7e4f74924811be04d7ef5f20deb5962ccc917c763cadbfd6e71725d4dc477c30
CREDS_KEY=3b40bd55e41f041b6968cd605cc64e91406ffe002a9ea3265b5722836a40ad91
CREDS_IV=54c86186ddc43f85feb7cb55d3fae159
MEILI_MASTER_KEY=6ed921fc21dcdb7b275b3fd51a7052004fbd46c172e0992b
SEARCH=true
MEILI_NO_ANALYTICS=true
MONGO_URI=mongodb://mongodb:27017/LibreChat
MEILI_HOST=http://meilisearch:7700
RAG_PORT=8000
RAG_API_URL=http://rag_api:8000
CONFIG_PATH=/app/librechat.yaml
NO_INDEX=true
DEBUG_LOGGING=false

# ── Pipelines Service ─────────────────────────────────────────
# API key compartilhada entre LibreChat e Pipelines (librechat.yaml)
PIPELINES_API_KEY=TMHNJopG01z322Gw2s2JAA8381wqPOVnVa

# ── Sandbox ───────────────────────────────────────────────────
# gRPC port exposed by the fixed cappycloud-sandbox service.
SANDBOX_GRPC_PORT=50051

# Seconds of inactivity before a worktree session is destroyed
SANDBOX_IDLE_TIMEOUT=1800

# ── External / host ports ─────────────────────────────────────
# Non-standard ports to avoid collisions with common dev tools
# (Next.js / Vite / CRA use 3000; standard HTTP is 8080).
# Optional: expose PostgreSQL and Redis to the host for debugging.
# Remove these mappings from docker-compose.yml in production.
POSTGRES_PORT=15432
REDIS_PORT=16379

DEVOPS_TOKEN=DK...

# ── Code Indexer + Neo4j ──────────────────────────────────────
# Serviço de indexação de código (pgvector + grafo AST Neo4j).
# Reindexado automaticamente a cada vez que um workspace inicia.

# Senha do Neo4j (o usuário é sempre "neo4j")
NEO4J_PASSWORD=cappyneo4j

# Modelo de embeddings (sentence-transformers, baixado durante o build)
# Alternativas leves: all-MiniLM-L6-v2 (384 dims, ~80 MB)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Porta do code-indexer no host (para debug / inspecionar índice)
INDEXER_PORT=38090

# Porta Bolt do Neo4j no host (para inspecionar com Neo4j Browser)
NEO4J_BOLT_PORT=17687


WORKSPACE_REPOS=
